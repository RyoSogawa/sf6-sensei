---
import { Image } from 'astro:assets'
import usage1 from '../assets/usage-1.png'
import usage2 from '../assets/usage-2.png'
import usage3 from '../assets/usage-3.png'
import usage4 from '../assets/usage-4.png'
import usage5 from '../assets/usage-5.png'
import CopyUrl from '../components/CopyUrl.astro'
import Base from '../layouts/Base.astro'
import '@splidejs/splide/css/core'

const base = import.meta.env.BASE_URL
const connectUrl = 'https://sf6-sensei-mcp.msnsgw.workers.dev/'

const slides = [
  {
    alt: 'Claude で SF6 Sensei に「マッチング ＜キャラ名＞」とメッセージすると、そのキャラの5項目をまとめさせるカスタム指示の例',
    src: usage5,
  },
  {
    alt: 'Claude で SF6 Sensei を使い、ベガのターゲットコンボのガード時フレームを質問している例',
    src: usage1,
  },
  {
    alt: 'Claude で SF6 Sensei を使い、ケンの全 SA の無敵性能を質問している例',
    src: usage2,
  },
  {
    alt: 'Claude で SF6 Sensei を使い、キャミィの SA でインパクトが確定しないものを質問している例',
    src: usage3,
  },
  {
    alt: 'Claude で SF6 Sensei を使い、ルークの弱攻撃のジャストパリィ時の有利フレームを質問している例',
    src: usage4,
  },
]
---

<Base
  title="SF6 Sensei — Street Fighter 6 フレームデータ MCP サーバー"
  description="Street Fighter 6 のフレームデータを ChatGPT / Claude から引ける非公式 MCP サーバー。接続手順を案内します。"
>
  <div class="hero">
    <div class="wrap">
      <h1>対戦中に手放しでフレームを調べる</h1>
      <p>
        Street Fighter 6 の発生・硬直差・確定反撃の候補を、テキストチャットの音声入力でそのまま質問できる非公式
        MCP サーバーです。
      </p>
      <p class="source">※データ出典は SuperCombo Wiki（CC-BY-SA）。</p>
    </div>
    <section class="usage-carousel splide" aria-label="利用イメージ">
      <div class="splide__track">
        <ul class="splide__list">
          {
            slides.map((slide, i) => (
              <li class="splide__slide">
                <Image
                  src={slide.src}
                  alt={slide.alt}
                  widths={[440, 720, 1200]}
                  sizes="(max-width: 760px) 90vw, 700px"
                  format="webp"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </div>

  <main>
    <section id="about">
      <div class="wrap">
        <h2><span class="num">?</span>これは何</h2>
        <p>
          <strong>SF6 Sensei</strong> は、Street Fighter 6 のフレームデータを Model Context
          Protocol（MCP）で配信するサーバーです。ChatGPT や Claude
          にコネクタとして登録すると、「ジュリの2強の発生は？」「この技ガードした、確反ある？」
          のように自然言語で聞けるようになります。
        </p>
        <div class="note">
          <strong>音声入力で使う前提です。</strong>
          ChatGPT / Claude の<strong>リアルタイム音声会話（Voice Mode）では MCP
          ツールが発火しません</strong
          >。テキストチャット画面の音声入力（ディクテーション）で質問してください。
        </div>
      </div>
    </section>

    <section id="connect">
      <div class="wrap">
        <h2><span class="num">1</span>登録手順</h2>
        <p>
          お使いのクライアントのカスタムコネクタに、接続 URL
          を登録するだけです。認証は不要です（読み取り専用）。下のタブから手順を選んでください。
        </p>
        <div x-data="{ tab: null }">
          <div class="tabs" role="tablist" aria-label="クライアント選択">
            <button
              type="button"
              role="tab"
              id="tab-chatgpt"
              aria-controls="panel-chatgpt"
              :aria-selected="tab === 'chatgpt'"
              aria-selected="false"
              @click="tab = 'chatgpt'"
            >
              ChatGPT
            </button>
            <button
              type="button"
              role="tab"
              id="tab-claude"
              aria-controls="panel-claude"
              :aria-selected="tab === 'claude'"
              aria-selected="false"
              @click="tab = 'claude'"
            >
              Claude
            </button>
          </div>

          <div class="panel" role="tabpanel" id="panel-chatgpt" aria-labelledby="tab-chatgpt" x-show="tab === 'chatgpt'" x-cloak>
            <p class="updated">対応プラン: Plus / Pro / Business / Enterprise / Education（2026年6月時点）</p>
            <ol class="steps">
              <li>
                <strong>設定 → Apps → Advanced settings</strong> を開き、<strong>Developer mode</strong>
                をオンにする。
              </li>
              <li>
                <strong>設定 → Connectors</strong> で <strong>Create</strong>（カスタムコネクタの追加）を選ぶ。
              </li>
              <li>
                <strong>Connector URL</strong> に下の接続 URL を貼り付ける。
                <CopyUrl url={connectUrl} />
              </li>
              <li>認証は <strong>なし（Authless）</strong> を選択して追加する。</li>
              <li>
                ツール一覧が読み込まれたら完了。説明が変わったときは <strong>Refresh</strong> で再取得できる。
              </li>
            </ol>
          </div>

          <div class="panel" role="tabpanel" id="panel-claude" aria-labelledby="tab-claude" x-show="tab === 'claude'" x-cloak>
            <p class="updated">
              対応プラン: Free / Pro / Max / Team / Enterprise（Free はカスタムコネクタ1つまで・2026年6月時点）
            </p>
            <ol class="steps">
              <li><strong>Customize → Connectors</strong> を開く。</li>
              <li><strong>「+」→ Add custom connector</strong> を選ぶ。</li>
              <li>
                リモート MCP サーバー URL に下の接続 URL を入力する。
                <CopyUrl url={connectUrl} />
              </li>
              <li>認証情報は不要。<strong>Add</strong> をクリックして追加する。</li>
              <li>
                ツールが読み込まれたら完了。サーバーは公開インターネット上にある必要があります（VPN /
                ファイアウォール内は不可）。
              </li>
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section id="tools">
      <div class="wrap">
        <h2><span class="num">2</span>できること</h2>
        <p>登録すると、次の5つのツールが使えます。</p>
        <ul class="tools">
          <li>
            <code>get_move</code>
            <p>キャラ名と技名/入力/別名から、その技のフレームデータを引く。</p>
          </li>
          <li>
            <code>get_character_frame_data</code>
            <p>指定キャラの技一覧をまとめて取得する。</p>
          </li>
          <li>
            <code>search_moves</code>
            <p>発生やカテゴリなどの条件で技を横断検索する。</p>
          </li>
          <li>
            <code>find_punish</code>
            <p>ガード時の硬直差から、確定反撃の候補を提示する（候補のみ）。</p>
          </li>
          <li>
            <code>list_characters</code>
            <p>収録キャラの一覧を返す。</p>
          </li>
        </ul>
        <div class="note">
          <strong>find_punish は候補提示のみ:</strong>
          リーチ・距離・状況は考慮しません。完全な確反判定ではない点に注意してください。
        </div>
      </div>
    </section>

    <section id="rights">
      <div class="wrap">
        <h2><span class="num">i</span>権利・ライセンスについて</h2>
        <p>
          本ツールは Capcom とは一切関係のない、ファンメイドの非公式・非営利プロジェクトです。「Street
          Fighter」およびキャラクター名・技名は <a href="https://www.capcom.com/">株式会社カプコン</a
          >の商標・著作物です。
        </p>
        <p>
          フレームデータの出典は <a href="https://wiki.supercombo.gg/w/Street_Fighter_6">SuperCombo Wiki</a
          >（CC-BY-SA）です。詳細は<a href={`${base}licenses`}>権利・ライセンス</a>と<a
            href={`${base}terms`}>利用規約</a
          >をご覧ください。
        </p>
      </div>
    </section>
  </main>
</Base>

<script>
  import Splide from '@splidejs/splide'

  for (const el of document.querySelectorAll<HTMLElement>('.splide')) {
    new Splide(el, {
      type: 'loop',
      focus: 'center',
      autoWidth: true,
      gap: '2rem',
      autoplay: true,
      interval: 7000,
      speed: 500,
      pauseOnHover: true,
      height: '460px',
      breakpoints: {
        640: { arrows: false, gap: '1rem', height: '300px' },
      },
    }).mount()
  }
</script>
