---
import { getLangFromUrl, localizePath, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<footer class="site-footer">
  <div class="wrap">
    <span>{t('footer.tagline')}</span>
    <span>
      <a href={localizePath('terms', lang)}>{t('nav.terms')}</a> ·
      <a href={localizePath('licenses', lang)}>{t('nav.licenses')}</a> ·
      <a href="https://github.com/RyoSogawa/sf6-sensei">{t('nav.github')}</a>
    </span>
  </div>
</footer>
