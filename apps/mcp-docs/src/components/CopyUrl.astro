---
interface Props {
  url: string
}

const { url } = Astro.props
---

<div
  class="copy-field"
  x-data="{
    copied: false,
    async copy() {
      try {
        await navigator.clipboard.writeText(this.$refs.url.textContent.trim())
        this.copied = true
        setTimeout(() => (this.copied = false), 1800)
      } catch (_) {
        // クリップボード API が使えない/拒否された環境では何もしない
      }
    },
  }"
>
  <code x-ref="url">{url}</code>
  <button
    type="button"
    class="copy-btn"
    :class="{ copied }"
    x-text="copied ? 'コピーしました' : 'コピー'"
    @click="copy()"
  >
    コピー
  </button>
</div>
