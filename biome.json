{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "extends": ["@repo/biome-config"],
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!**/dist", "!**/.wrangler", "!**/node_modules", "!scripts", "!**/generated"]
  },
  "overrides": [
    {
      "includes": ["apps/scraper/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ],
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  }
}
